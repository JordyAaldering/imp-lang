trait Add :: (T, T) -> T;

impl Add :: (u32, u32) -> u32 {
    fn +(u32 a, u32 b) -> u32 {
        return @addSxS(a, b);
    }
}

impl Add :: (usize, usize) -> usize {
    fn +(usize a, usize b) -> usize {
        return @addSxS(a, b);
    }
}

impl Add :: (U[d:shp], U[d:shp]) -> U[d:shp]
{
    fn +(U[d:shp] a, U[d:shp] b) -> U[d:shp] {
        return { a[iv] + b[iv] | iv < shp };
    }
}
