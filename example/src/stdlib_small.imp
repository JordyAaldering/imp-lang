trait Add<T> {
    fn +(T a, T b) -> T;
}

impl Add<u32> {
    fn +(u32 a, u32 b) -> u32 {
        return @addSxS(a, b);
    }
}

impl Add<usize> {
    fn +(usize a, usize b) -> usize {
        return @addSxS(a, b);
    }
}

impl Add<U[d:shp]>
    where U: Add
{
    fn +(U[d:shp] a, U[d:shp] b) -> U[d:shp] {
        return { a[iv] + b[iv] | iv < shp };
    }
}
