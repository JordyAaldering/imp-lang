fn addthem(u32 a, u32 b, u32 c) -> u32 {
    return a + b + c;
}

fn makevector(u32 ub) -> u32[ub] {
    lb = 0;
    res = { 1 + iv + ub | lb <= iv < ub };
    return res;
}

fn makematrix(u32 cols, u32 rows) -> u32[colsrows] {
    res = { { iv + jv | 0 <= jv < cols }
          | 0 <= iv < rows };
    return res;
}
