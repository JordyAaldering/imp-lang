fn makevector(u32 ub) -> u32[ub] {
    lb = [0usize];
    zero = [0usize];
    res = { @addSxS(@addSxS(1u32, @selVxA(zero, iv)), ub) | lb <= iv < [ub] };
    return res;
}

fn makematrix(u32 cols, u32 rows) -> u32[cols,rows] {
    res = { { @addSxS(@selVxA([0usize], iv), @selVxA([0usize], jv)) | [0usize] <= jv < [cols] }
          | [0usize] <= iv < [rows] };
    return res;
}
